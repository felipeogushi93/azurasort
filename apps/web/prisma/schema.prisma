generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Giveaway {
  id            String         @id @default(cuid())
  postUrl       String
  shortcode     String?
  campaign      String
  totalComments Int            @default(0)
  status        String         @default("created")
  createdAt     DateTime       @default(now())
  draws         Draw[]
  payments      Payment[]
  forced        ForcedWinner[]

  @@index([shortcode])
}

model Draw {
  id              String   @id @default(cuid())
  giveawayId      String
  giveaway        Giveaway @relation(fields: [giveawayId], references: [id])
  module          String   @default("bank_vault")
  seedHash        String // commit: SHA-256 da seed, publicado ANTES
  seed            String? // revelado DEPOIS
  algorithm       String   @default("sha256-commit-reveal-fisher-yates")
  totalCount      Int      @default(0)
  eligibleCount   Int      @default(0)
  certificateCode String   @unique
  rigged          Boolean  @default(false)
  participants    Json? // lista ordenada de @handles elegíveis (auditoria/verify)
  createdAt       DateTime @default(now())
  winners         Winner[]

  @@index([giveawayId])
}

model Winner {
  id       String  @id @default(cuid())
  drawId   String
  draw     Draw    @relation(fields: [drawId], references: [id])
  position Int
  handle   String
  isBackup Boolean @default(false)

  @@index([drawId])
}

model Payment {
  id                 String    @id @default(cuid())
  provider           String // stripe | woovi
  externalId         String    @unique
  amount             Int
  currency           String    @default("BRL")
  plan               String    @default("premium")
  status             String    @default("pending") // pending | paid | failed
  giveawayId         String?
  giveaway           Giveaway? @relation(fields: [giveawayId], references: [id])
  createdAt          DateTime  @default(now())
  paidAt             DateTime?
  gclid              String?
  email              String?
  phone              String?
  conversionUploaded Boolean   @default(false)

  @@index([giveawayId])
  @@index([status, paidAt])
}

// Ganhador pré-selecionado pelo admin (painel). runIndex: 0=1ª rodada, 1=2ª, 2=3ª.
model ForcedWinner {
  id         String    @id @default(cuid())
  giveawayId String
  giveaway   Giveaway  @relation(fields: [giveawayId], references: [id])
  runIndex   Int
  handle     String
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@unique([giveawayId, runIndex])
}

// Eventos para KPIs / funil
model Event {
  id        String   @id @default(cuid())
  type      String // visit | link_loaded | unlock_view | pay_started | pay_done | draw_done
  sessionId String?
  ip        String?
  country   String?
  path      String?
  bot       Boolean  @default(false) // true = crawler/robô (user-agent conhecido) — filtrado do painel
  ua        String? // user-agent (auditar bot vs pessoa)
  meta      Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([type, bot, createdAt])
  @@index([sessionId, type])
}

// 🚨 RESGATE MANUAL (admin cola comentários do IG quando o scraping pega pouco).
// Feature isolada — para remover: apague este model, /app/adminlkgat/RescuePanel.tsx,
// /app/api/admin/rescue, lib/draw/parseIg.ts e o bloco "RESCUE manual" em /api/draw.
model ManualPool {
  id        String   @id @default(cuid())
  shortcode String   @unique
  postUrl   String
  handles   Json // [{ handle, text }]
  owner     String?
  totalReal Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
